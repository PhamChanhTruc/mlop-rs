GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
ARTIFACT_REGISTRY_REPO=mlops-rs-images
CLOUD_RUN_SERVICE=mlops-rs-inference
IMAGE_TAG=latest

# Service runtime environment variables consumed by serving.app
MODEL_URI=models:/xgb-baseline-retailrocket/Production
MLFLOW_TRACKING_URI=https://YOUR-MLFLOW-ENDPOINT
MLFLOW_EXPERIMENT=xgb-baseline-retailrocket
PREDICTION_THRESHOLD=0.5
FEAST_REPO_PATH=/app/feature_repo

# Cloud Run service sizing
CLOUD_RUN_MEMORY=1Gi
CLOUD_RUN_CPU=1
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=2

# Feast / Redis note:
# The current top-level feature_repo/feature_store.yaml uses
#   online_store.connection_string: redis:6379
# That works in local Docker Compose, but not in Cloud Run.
# For Cloud Run, you still need a reachable Redis-backed Feast online store and
# must update feature_repo/feature_store.yaml or provide an equivalent cloud-specific
# Feast repo config before Feast-backed online inference will work.
