{
  "id": null,
  "uid": "mlops-overview",
  "title": "MLOps API Overview",
  "tags": ["mlops", "inference"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Requests / sec (5m)",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Error Rate % (5m)",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(inference_errors_total[5m])) / clamp_min(sum(rate(inference_requests_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Latency p95 (5m)",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Predicted Positive Rate % (5m)",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(model_output_positive_total[5m])) / clamp_min(sum(rate(inference_requests_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Request Count by Status (5m rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[5m]))",
          "legendFormat": "requests",
          "refId": "A"
        },
        {
          "expr": "sum(rate(inference_errors_total[5m]))",
          "legendFormat": "errors",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Model Output Probability Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "sum(rate(model_output_proba_bucket[5m])) by (le)",
          "legendFormat": "<= {{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Model Output Signals",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "expr": "model_output_proba_last",
          "legendFormat": "last_proba",
          "refId": "A"
        },
        {
          "expr": "sum(rate(model_output_proba_sum[5m])) / clamp_min(sum(rate(model_output_proba_count[5m])), 1e-9)",
          "legendFormat": "avg_proba_5m",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  }
}
